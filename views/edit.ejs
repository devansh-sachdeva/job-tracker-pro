<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Application | JobTracker Pro</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/auth.css">
  <link rel="stylesheet" href="/css/form.css">
</head>
<body>
  <nav class="navbar">
    <div class="nav-container">
      <div class="nav-brand">
        <div class="logo-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
            <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
          </svg>
        </div>
        <span class="logo-text">JobTracker Pro</span>
      </div>
      <div class="nav-menu">
        <a href="/dashboard" class="btn btn-back">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="19" y1="12" x2="5" y2="12"/>
            <polyline points="12 19 5 12 12 5"/>
          </svg>
          <span>Back</span>
        </a>
      </div>
    </div>
  </nav>

  <main class="main-content">
    <div class="form-container">
      <div class="form-card">
        <div class="form-header">
          <h1 class="form-title">Edit Application</h1>
          <p class="form-subtitle">Update your job application details</p>
        </div>

        <% if (error) { %>
          <div class="toast toast-error">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <line x1="15" y1="9" x2="9" y2="15"/>
              <line x1="9" y1="9" x2="15" y2="15"/>
            </svg>
            <span><%= error %></span>
          </div>
        <% } %>

        <form action="/edit/<%= application.id %>" method="POST" class="job-form">
          <div class="form-row">
            <div class="form-group">
              <label for="company_name">Company Name *</label>
              <div class="input-wrapper">
                <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
                  <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
                </svg>
                <input type="text" id="company_name" name="company_name" value="<%= application.company_name %>" required>
              </div>
            </div>

            <div class="form-group">
              <label for="job_role">Job Role *</label>
              <div class="input-wrapper">
                <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                  <circle cx="12" cy="7" r="4"/>
                </svg>
                <input type="text" id="job_role" name="job_role" value="<%= application.job_role %>" required>
              </div>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="date_applied">Date Applied *</label>
              <div class="input-wrapper">
                <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                  <line x1="16" y1="2" x2="16" y2="6"/>
                  <line x1="8" y1="2" x2="8" y2="6"/>
                  <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
                <input type="date" id="date_applied" name="date_applied" value="<%= application.date_applied instanceof Date ? application.date_applied.toISOString().split('T')[0] : application.date_applied %>" required>
              </div>
            </div>

            <div class="form-group">
              <label for="status">Status</label>
              <div class="input-wrapper">
                <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                  <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
                <select id="status" name="status">
                  <option value="Applied" <%= application.status === 'Applied' ? 'selected' : '' %>>Applied</option>
                  <option value="Interview Scheduled" <%= application.status === 'Interview Scheduled' ? 'selected' : '' %>>Interview Scheduled</option>
                  <option value="Offer Received" <%= application.status === 'Offer Received' ? 'selected' : '' %>>Offer Received</option>
                  <option value="Rejected" <%= application.status === 'Rejected' ? 'selected' : '' %>>Rejected</option>
                </select>
              </div>
            </div>
          </div>

          <div class="form-group">
            <label for="job_url">Job Posting URL</label>
            <div class="input-wrapper">
              <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
              </svg>
              <input type="url" id="job_url" name="job_url" value="<%= application.job_url || '' %>" placeholder="https://...">
            </div>
          </div>

          <div class="form-group">
            <label for="notes">Notes</label>
            <div class="input-wrapper textarea-wrapper">
              <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
              </svg>
              <textarea id="notes" name="notes" placeholder="Add any notes about this application..." rows="4"><%= application.notes || '' %></textarea>
            </div>
          </div>

          <div class="form-actions">
            <a href="/dashboard" class="btn btn-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary">
              <span>Update Application</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </button>
          </div>
        </form>
      </div>
    </div>
  </main>
</body>
</html>
