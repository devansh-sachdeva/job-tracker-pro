<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard | JobTracker Pro</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
  <nav class="navbar">
    <div class="nav-container">
      <div class="nav-brand">
        <div class="logo-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
            <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
          </svg>
        </div>
        <span class="logo-text">JobTracker Pro</span>
      </div>
      <div class="nav-menu">
        <div class="nav-user">
          <div class="user-avatar">
            <%= user.email.charAt(0).toUpperCase() %>
          </div>
          <span class="user-email"><%= user.email %></span>
        </div>
        <a href="/logout" class="btn btn-logout">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
            <polyline points="16 17 21 12 16 7"/>
            <line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
          <span>Logout</span>
        </a>
      </div>
    </div>
  </nav>

  <main class="main-content">
    <div class="container">
      <header class="page-header">
        <div class="header-content">
          <h1 class="page-title">Job Applications</h1>
          <p class="page-subtitle">Track and manage all your job applications in one place</p>
        </div>
        <a href="/add" class="btn btn-add">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19"/>
            <line x1="5" y1="12" x2="19" y2="12"/>
          </svg>
          <span>Add Application</span>
        </a>
      </header>

      <section class="stats-grid">
        <div class="stat-card stat-total" data-aos="fade-up" data-aos-delay="0">
          <div class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
            </svg>
          </div>
          <div class="stat-info">
            <span class="stat-value" data-target="<%= stats.total %>">0</span>
            <span class="stat-label">Total Applications</span>
          </div>
        </div>

        <div class="stat-card stat-applied" data-aos="fade-up" data-aos-delay="100">
          <div class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div class="stat-info">
            <span class="stat-value" data-target="<%= stats.applied %>">0</span>
            <span class="stat-label">Applied</span>
          </div>
        </div>

        <div class="stat-card stat-interview" data-aos="fade-up" data-aos-delay="200">
          <div class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
          </div>
          <div class="stat-info">
            <span class="stat-value" data-target="<%= stats.interview %>">0</span>
            <span class="stat-label">Interviews</span>
          </div>
        </div>

        <div class="stat-card stat-offer" data-aos="fade-up" data-aos-delay="300">
          <div class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="8" r="7"/>
              <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/>
            </svg>
          </div>
          <div class="stat-info">
            <span class="stat-value" data-target="<%= stats.offer %>">0</span>
            <span class="stat-label">Offers</span>
          </div>
        </div>

        <div class="stat-card stat-rejected" data-aos="fade-up" data-aos-delay="400">
          <div class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <line x1="15" y1="9" x2="9" y2="15"/>
              <line x1="9" y1="9" x2="15" y2="15"/>
            </svg>
          </div>
          <div class="stat-info">
            <span class="stat-value" data-target="<%= stats.rejected %>">0</span>
            <span class="stat-label">Rejected</span>
          </div>
        </div>
      </section>

      <section class="filter-section">
        <div class="filter-bar">
          <div class="search-wrapper">
            <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/>
              <line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input type="text" id="searchInput" class="search-input" placeholder="Search by company name...">
          </div>
          <div class="filter-buttons">
            <button class="filter-btn active" data-status="All">All</button>
            <button class="filter-btn" data-status="Applied">Applied</button>
            <button class="filter-btn" data-status="Interview Scheduled">Interviews</button>
            <button class="filter-btn" data-status="Offer Received">Offers</button>
            <button class="filter-btn" data-status="Rejected">Rejected</button>
          </div>
        </div>
      </section>

      <section class="applications-section">
        <% if (applications.length === 0) { %>
          <div class="empty-state">
            <div class="empty-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
                <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
              </svg>
            </div>
            <h3>No Applications Yet</h3>
            <p>Start tracking your job applications by adding your first one</p>
            <a href="/add" class="btn btn-add">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
              <span>Add Your First Application</span>
            </a>
          </div>
        <% } else { %>
          <div class="table-container">
            <table class="applications-table">
              <thead>
                <tr>
                  <th>Company</th>
                  <th>Role</th>
                  <th>Date Applied</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="applicationsTable">
                <% applications.forEach((app, index) => { %>
                  <tr class="application-row" data-status="<%= app.status %>" data-company="<%= app.company_name.toLowerCase() %>" style="animation-delay: <%= index * 50 %>ms">
                    <td>
                      <div class="company-cell">
                        <div class="company-avatar">
                          <%= app.company_name.charAt(0).toUpperCase() %>
                        </div>
                        <span class="company-name"><%= app.company_name %></span>
                      </div>
                    </td>
                    <td class="role-cell"><%= app.job_role %></td>
                    <td class="date-cell">
                      <span class="date-text"><%= new Date(app.date_applied).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                    </td>
                    <td>
                      <span class="status-badge status-<%= app.status.toLowerCase().replace(/\s+/g, '-') %>">
                        <%= app.status %>
                      </span>
                    </td>
                    <td>
                      <div class="action-buttons">
                        <a href="/edit/<%= app.id %>" class="btn-icon btn-edit" title="Edit">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                          </svg>
                        </a>
                        <form action="/delete/<%= app.id %>" method="POST" class="delete-form" onsubmit="return confirm('Are you sure you want to delete this application?');">
                          <button type="submit" class="btn-icon btn-delete" title="Delete">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                              <polyline points="3 6 5 6 21 6"/>
                              <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                              <line x1="10" y1="11" x2="10" y2="17"/>
                              <line x1="14" y1="11" x2="14" y2="17"/>
                            </svg>
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </section>
    </div>
  </main>

  <div id="toast" class="toast-container"></div>

  <script src="/js/dashboard.js"></script>
</body>
</html>
